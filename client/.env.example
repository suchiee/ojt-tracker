# InternSync Client Environment Configuration Example

# Supabase Public API credentials (Safe for client bundle)
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-supabase-public-anon-key-placeholder

# Backend API base URL
# Development (with package.json proxy): leave empty or use /api/v2
# Staging/Production: set to full backend URL, e.g. https://api.internsync.edu.ph/api/v2
REACT_APP_API_URL=/api/v2
